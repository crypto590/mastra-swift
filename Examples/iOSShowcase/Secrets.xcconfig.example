// Copy this file to `Secrets.xcconfig` and fill in the three values below.
// The real file is gitignored so your keys never land in source control.
//
// Xcode picks up changes when you Clean Build Folder (Shift-Cmd-K) + rebuild.

// Base URL of your running Mastra server.
// Local dev:  http://localhost:4111
// Deployed:   https://your-mastra.example.com
MASTRA_BASE_URL = http:/$()/localhost:4111

// Agent id registered on your Mastra server (see src/mastra/index.ts).
MASTRA_AGENT_ID = assistant

// Optional. Leave empty if your server is unauthenticated.
MASTRA_API_KEY =
